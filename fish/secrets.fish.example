# Secret environment variables template
# Copy to ~/.config/fish/conf.d/secrets.fish and fill in your values
# This file is safe to commit — it contains NO real secrets

# Meta for Developers
set -gx META_APP_ID ""
set -gx META_APP_SECRET ""
set -gx META_SYSTEM_USER_TOKEN ""

# Meta Business
set -gx META_BUSINESS_ID ""
set -gx META_AD_ACCOUNT_ID ""  # format: act_XXXXXXXXX

# WhatsApp Business
set -gx META_WHATSAPP_BUSINESS_ACCOUNT_ID ""
set -gx META_WHATSAPP_PHONE_NUMBER_ID ""
set -gx META_WHATSAPP_PHONE_NUMBER ""

# Google Cloud
# Credentials handled by: gcloud auth application-default login
# set -gx GOOGLE_PROJECT_ID ""

# AWS
# Credentials handled by: aws configure
# Keys stored in ~/.aws/credentials

# Add other secrets below...
